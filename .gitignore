# aiprofil — real profile .env files hold live API/foundry/SSH keys; only the
# *.example templates and .managed-vars are committed. The legacy cc-profil/
# path is kept ignored too, for installs that still carry profiles there.
aiprofil/profiles/*.env
!aiprofil/profiles/*.env.example
cc-profil/profiles/*.env
!cc-profil/profiles/*.env.example

