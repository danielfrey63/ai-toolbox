#!/bin/sh
# pre-commit — bump the MINOR segment of every staged artifact.
#
# Part of the AI-Toolbox versioning system. The per-edit PostToolUse hook bumps
# BUILD; this hook bumps MINOR once per commit. Build and minor are different
# segments, so the two bumps never collide.
#
# Every staged file is resolved to its artifact (bump-version.sh --target),
# duplicates are collapsed, each artifact's minor is bumped once, and the
# bumped files are re-staged so the change joins this commit. The staged file
# list is git's own record of what changed — no version comparison needed.
#
# Logic lives here (version-controlled). .git/hooks/pre-commit is a thin shim
# pointing at this file, installed by tools/install-hooks.sh.

APP_VERSION='0.2.3'

repo=$(git rev-parse --show-toplevel) || exit 0
bump="$repo/tools/bump-version.sh"
[ -x "$bump" ] || exit 0

# Resolve staged files (added/copied/modified) to unique artifact targets.
targets=$(
    git diff --cached --name-only --diff-filter=ACM | while IFS= read -r f; do
        [ -n "$f" ] && [ -f "$repo/$f" ] && "$bump" --target "$repo/$f"
    done | sort -u
)
[ -n "$targets" ] || exit 0

# Bump each artifact's minor once and re-stage it.
printf '%s\n' "$targets" | while IFS= read -r t; do
    [ -n "$t" ] || continue
    "$bump" --minor "$t"
    git add -- "$t"
done
exit 0
