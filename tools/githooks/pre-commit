#!/bin/sh
# pre-commit — bump MINOR+BUILD of every staged artifact.
#
# Part of the AI-Toolbox versioning system. The per-edit PostToolUse hook bumps
# BUILD on every edit; this hook bumps MINOR and BUILD once per commit — so
# MINOR counts commits while BUILD counts every iteration.
#
# Every staged file is resolved to its artifact (bump-version.sh --target),
# duplicates are collapsed, each artifact is bumped once (--commit), and the
# bumped files are re-staged so the change joins this commit. The staged file
# list is git's own record of what changed — no version comparison needed.
#
# Invoked by the managed shim line that `toolbox install --what versioning-hooks`
# writes into a repo's pre-commit (see <ai-toolbox>/toolbox.sh). Works for any
# repo: the hook resolves the AI-Toolbox from its own path, so bump-version.sh is
# found even when this runs inside a foreign repo.

APP_VERSION='0.8.17'

repo=$(git rev-parse --show-toplevel) || exit 0
# This hook lives in <ai-toolbox>/tools/githooks/ — resolve bump-version.sh
# from the hook's own path (not $repo), so it works when core.hooksPath points
# a foreign repo at this directory.
toolbox=$(cd "$(dirname "$0")/../.." 2>/dev/null && pwd) || exit 0
bump="$toolbox/tools/bump-version.sh"
[ -x "$bump" ] || exit 0

# Gate (AI-Toolbox repo only): staged catalog or SKILL.md changes must pass
# `toolbox validate` before the commit proceeds. In foreign repos $repo and
# $toolbox differ and the gate is skipped. Under git-bash $repo is Windows-
# style (D:/…) while $toolbox is MSYS-style (/d/…), so string equality alone
# is not enough — -ef compares the actual directories (same idiom as
# _same_hookpath in toolbox.sh).
if { [ "$repo" = "$toolbox" ] || [ "$repo" -ef "$toolbox" ] 2>/dev/null; } \
    && [ -x "$toolbox/toolbox.sh" ]; then
    if git diff --cached --name-only --diff-filter=ACMDR \
        | grep -qE '^tools/catalog\.json$|(^|/)SKILL\.md$'; then
        if ! "$toolbox/toolbox.sh" validate; then
            echo "pre-commit: toolbox validate failed — fix the catalog/disk mismatch before committing." >&2
            exit 1
        fi
    fi
fi

# Resolve staged files (added/copied/modified) to unique artifact targets.
targets=$(
    git diff --cached --name-only --diff-filter=ACM | while IFS= read -r f; do
        [ -n "$f" ] && [ -f "$repo/$f" ] && "$bump" --target "$repo/$f"
    done | sort -u
)
[ -n "$targets" ] || exit 0

# Bump each artifact's minor+build once and re-stage it.
printf '%s\n' "$targets" | while IFS= read -r t; do
    [ -n "$t" ] || continue
    "$bump" --commit "$t"
    git add -- "$t"
done
exit 0
