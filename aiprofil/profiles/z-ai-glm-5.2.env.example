# =============================================================================
# Devbox Profil: Z.ai GLM-5.2
# =============================================================================

# --- Anthropic-compatible Z.ai endpoint ---
CLAUDE_CODE_USE_FOUNDRY=0
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_AUTH_TOKEN=your-api-token
ANTHROPIC_API_KEY=your-api-key
API_TIMEOUT_MS=3000000

# Modelle (ohne Anfuehrungszeichen!)
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.2
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5.2
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-5.2
ANTHROPIC_SMALL_FAST_MODEL=glm-5.2
CLAUDE_CODE_SUBAGENT_MODEL=glm-5.2

# --- Kilo Code projection (consumed by kilo-profil; omit to skip Kilo) ---
# KILO_PROVIDER_ID must match a provider.<id> block in kilo.jsonc.
KILO_PROVIDER_ID=sample-anthropic-provider-id
KILO_ACTIVE_MODEL=glm-5.2
KILO_SMALL_MODEL=glm-5.2

# --- Agent Teams ---
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# --- Git ---
GIT_USER_NAME=sample-git-user
GIT_USER_EMAIL=sample.user@sample.com

# --- SSH-Zugang ---
SSH_AUTHORIZED_KEYS=ssh-ed25519 AAAA...dein-public-key-hier

# --- Optional ---
CLAUDE_DANGEROUSLY_SKIP_PERMISSIONS=true
