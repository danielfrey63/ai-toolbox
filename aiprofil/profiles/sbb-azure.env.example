# =============================================================================
# Devbox Profil: SBB Azure AI Foundry
# =============================================================================
CC_PROFILE=your-devbox-profile

# --- Microsoft Foundry ---
CLAUDE_CODE_USE_FOUNDRY=1
ANTHROPIC_FOUNDRY_RESOURCE=sample-azure-ai-foundry-resource
ANTHROPIC_FOUNDRY_API_KEY=your-azure-api-key

# Modelle (ohne Anfuehrungszeichen!)
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5

# --- Kilo Code projection (optional; consumed by kilo-profil) ---
# Omit this whole block to make the profile CC-only (Kilo target skipped).
# KILO_PROVIDER_ID must match a provider.<id> block in your kilo.jsonc;
# the baseURL is derived from ANTHROPIC_FOUNDRY_RESOURCE, the key reused
# from ANTHROPIC_FOUNDRY_API_KEY. Model values are kilo.jsonc model ids.
KILO_PROVIDER_ID=sample-anthropic-provider-id
KILO_ACTIVE_MODEL=claude-opus-4-7
KILO_SMALL_MODEL=claude-haiku-4-5

# --- Agent Teams ---
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# --- Git ---
GIT_USER_NAME=sample-git-user
GIT_USER_EMAIL=sample.user@sample.com

# --- SSH-Zugang ---
SSH_AUTHORIZED_KEYS=ssh-ed25519 AAAA...dein-public-key-hier

# --- Optional ---
CLAUDE_DANGEROUSLY_SKIP_PERMISSIONS=true
