# =============================================================================
# oracle-skill — connection config (TEMPLATE)
# =============================================================================
# Copy to ./oracle.env (gitignored) and fill in. NEVER commit the real file.
# The password is read at connection-save time and stored in SQLcl's secure
# store / wallet — it does NOT stay in this file beyond first `install`, and
# it is never exposed to the MCP client (the model queries via a named
# connection, not via raw credentials).
#
# Pick EXACTLY ONE connection style and leave the other block commented.
# =============================================================================

# Logical name of the saved SQLcl connection the MCP server will expose.
ORACLE_CONN_NAME=hackathon

# Database user.
ORACLE_USER=app_user

# Password source (in order of precedence):
#   1. ORACLE_PASSWORD env var (e.g. injected by a secret manager) — preferred
#   2. interactive prompt at `install` time (never written back here)
# Leave empty to be prompted. If set, it is consumed once and not persisted here.
ORACLE_PASSWORD=

# --- Style A: Easy Connect (on-prem / direct host) ---------------------------
# Classic host:port/service_name. Typical for internal instances.
ORACLE_HOST=db.internal.example.com
ORACLE_PORT=1521
ORACLE_SERVICE=ORCLPDB1

# --- Style B: Wallet / TNS alias (Autonomous DB, mTLS) -----------------------
# Uncomment and use INSTEAD of Style A. Point TNS_ADMIN at the unzipped wallet
# directory containing tnsnames.ora + sqlnet.ora; ORACLE_TNS_ALIAS is an entry
# from that tnsnames.ora (e.g. mydb_high).
# TNS_ADMIN=/absolute/path/to/wallet
# ORACLE_TNS_ALIAS=mydb_high

# --- MCP client registration target -----------------------------------------
# Where `install` registers (and `cleanup` unregisters) the `sql -mcp` server:
#   print   — only emit the registration snippet, change nothing (default, safe)
#   claude  — register with Claude Code via `claude mcp add` (idempotent)
#   kilo    — insert/remove a self-marked `oracle` block in Kilo's kilo.jsonc,
#             idempotently and comment-preserving (no jq); a .bak is written
#             before each change. See README "JSONC handling (Kilo)".
ORACLE_MCP_CLIENT=print

# Kilo config path (only for ORACLE_MCP_CLIENT=kilo). Leave empty for auto-detect:
#   ~/.config/kilo/kilo.jsonc, else ~/.config/kilo.jsonc.
# ORACLE_KILO_CONFIG=
