# /watch API configuration - canonical template.
#
# setup.py copies this file to ~/.config/watch/.env on first run. Edit that
# copy (not this one) to add your keys, or run `python scripts/setup.py` for
# an interactive wizard. Values can also be supplied as real environment
# variables, which take precedence over the file.
#
# ===========================================================================
# Whisper transcription (used when yt-dlp cannot get native captions, or for
# local files without subtitles).
#
# Groq is preferred: whisper-large-v3 at a fraction of OpenAI's price, faster
# in practice. OpenAI is the compatible fallback.
#   Groq key:    https://console.groq.com/keys
#   OpenAI key:  https://platform.openai.com/api-keys
#
# Leave both blank to disable Whisper - /watch still works, but videos with
# no native captions come back frames-only.

GROQ_API_KEY=
OPENAI_API_KEY=

# ===========================================================================
# Azure OpenAI - gpt-4o-transcribe-diarize (recommended for private content).
#
# A single deployment that does transcription AND speaker diarization in one
# call - the secure-backend equivalent of AssemblyAI. When both URL and KEY
# below are set, /watch prefers this backend automatically for transcription:
# audio stays on your Azure tenant, never touching Groq / OpenAI-public.
#
# URL is the full endpoint including the ?api-version=... query string -
# copy it verbatim from the Azure portal / AI Foundry deployment page, e.g.
#   https://<resource>.cognitiveservices.azure.com/openai/deployments/
#     gpt-4o-transcribe-diarize/audio/transcriptions?api-version=2025-03-01-preview
# Auth is the api-key header (Azure OpenAI standard).

AZURE_TRANSCRIBE_DIARIZE_URL=
AZURE_TRANSCRIBE_DIARIZE_KEY=

# Microsoft MAI-Transcribe-1 - an alternative speech-to-text deployment on
# the same secure backend. Under evaluation: if it accepts longer audio
# than gpt-4o-transcribe-diarize's 1500 s cap, it could transcribe long
# videos in fewer (or zero) chunks. Probe it with:
#   python scripts/azure_transcribe_test.py <audio> --backend mai --no-trim
# URL is the full endpoint incl. ?api-version=...; auth is the api-key header.

MAI_TRANSCRIBE_URL=
MAI_TRANSCRIBE_KEY=

# Claude (Anthropic) on Azure AI Foundry - used to reconcile speaker
# identity across transcription chunks. gpt-4o-transcribe-diarize caps at
# 1500 s, so long audio is chunked and each chunk diarized independently
# with chunk-local labels; claude-opus-4-7 reads every chunk's per-speaker
# text and resolves who-is-who globally. This is the Foundry Anthropic
# passthrough - the Messages API, NOT the Azure OpenAI shape:
#   https://<resource>.services.ai.azure.com/anthropic/v1/messages
# (exact auth header / anthropic-version validated at build time)

AZURE_CLAUDE_URL=
AZURE_CLAUDE_KEY=

# ===========================================================================
# Speaker diarization (optional, --diarize in watch.py).
#
# Interchangeable backends. /watch defaults to no diarization; `--diarize`
# opt-ins (auto-picks the first configured), `--diarize <backend>` forces one.
# Note: if the Azure block above is configured, that already covers
# diarization - these are the non-Azure alternatives.
#
# AssemblyAI - cloud, all-in-one (transcription + speaker labels in one call).
# Replaces Whisper when --diarize=assemblyai. Pricing ~$0.37/h. Uses
# universal-3-pro (fallback universal-2) and language_detection by default.
#   Sign up / key:  https://www.assemblyai.com/dashboard/api-keys
# For EU data residency, also set ASSEMBLYAI_REGION=eu (routes through
# api.eu.assemblyai.com). Default is US (api.assemblyai.com).
#
# pyannote.ai - cloud, diarization-only. Runs alongside Whisper; the script
# aligns speaker turns to the Whisper transcript. Cheaper than AssemblyAI.
#   Sign up:  https://www.pyannote.ai/
#
# pyannote.audio (local) - open source, runs on your machine. Free but
# heavyweight (PyTorch model download). Needs:
#   pip install pyannote.audio
#   plus a Hugging Face token AND license acceptance for the model at
#   https://huggingface.co/pyannote/speaker-diarization-3.1
# Set the HF token in HF_TOKEN (or HUGGINGFACE_TOKEN) below.

ASSEMBLYAI_API_KEY=
# ASSEMBLYAI_REGION=us  # optional: 'us' (default) or 'eu' for EU data residency
PYANNOTE_API_KEY=
HF_TOKEN=

# ===========================================================================
# Markers (managed by setup.py - you normally do not edit these by hand).
#
# SETUP_COMPLETE=true   written once deps + a Whisper key are in place, so
#                       future sessions skip the wizard.
# DIARIZE_DISMISSED=true written by `setup.py --skip-diarize`; suppresses the
#                       "optional keys not set" hint for users who don't want
#                       speaker diarization at all.
