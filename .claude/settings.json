{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git -C \"$(git rev-parse --show-toplevel)\" pull --ff-only --quiet",
            "statusMessage": "git pull --ff-only..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/tools/bump-version.sh\"",
            "statusMessage": "APP_VERSION bump..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/tools/bump-from-bash.sh\"",
            "statusMessage": "APP_VERSION bump (bash)..."
          }
        ]
      }
    ]
  }
}
