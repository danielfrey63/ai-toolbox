{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& (Join-Path (git rev-parse --show-toplevel) 'tools/bump-version.ps1')\"",
            "timeout": 30,
            "statusMessage": "APP_VERSION bump"
          }
        ]
      }
    ]
  }
}
