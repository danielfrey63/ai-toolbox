# =============================================================================
# Devbox Profil: Max Subscription (claude login / OAuth)
# =============================================================================
# Kein API-Key noetig! Authentifizierung via: claude auth login
# POST_ACTIVATE_CMD wird von devbox-profile nach dem Aktivieren ausgefuehrt.
# =============================================================================
CC_PROFILE=max
POST_ACTIVATE_CMD=claude auth login

# --- Git ---
GIT_USER_NAME=sample-git-user
GIT_USER_EMAIL=sample.user@sample.com

# --- Agent Teams ---
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# --- Optional ---
CLAUDE_DANGEROUSLY_SKIP_PERMISSIONS=true

# --- SSH Zugang ---
SSH_AUTHORIZED_KEYS=ssh-ed25519 AAAA...dein-public-key-hier